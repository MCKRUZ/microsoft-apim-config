<!--
  ============================================================================
  LLM GOVERNANCE POLICY  -  Azure OpenAI API scope (COMPOSED FROM FLAGS)
  ============================================================================
  The heart of the "golden copy": the GA AI-gateway controls. As of the toggle
  framework, each control is a FEATURE FLAG — this file is the ordered skeleton,
  and llm-api.bicep splices each control's XML into the marker below ONLY when its
  flag is on (empty string when off, so a disabled control leaves NO dead policy).
  With every control flag at its default (on), the composed policy is identical to
  the original always-on seed.

  IMPORTANT — element order is significant. APIM requires the AI-gateway elements in
  the documented order; the markers are positioned to preserve it:
    auth -> [failover route] -> token-limit -> emit-token-metric -> content-safety
         -> semantic-cache-lookup   (inbound);   semantic-cache-store (outbound)

  Flag -> marker map (composed in infra/modules/llm-api.bicep):
    tokenRateLimit / tokenQuota / preflightReject -> TOKEN_LIMIT
    costAttribution                               -> EMIT_TOKEN_METRIC
    contentSafetyPrompt / contentSafetyResponse   -> CONTENT_SAFETY
    semanticCache                                 -> SEMANTIC_CACHE_LOOKUP / _STORE
    modelFailover                                 -> FAILOVER_BACKEND
  Named values (named-values.bicep): {{tokens-per-minute}} {{token-quota}}
    {{token-quota-period}} {{cache-score-threshold}}. Backend ids
    ('content-safety-backend','embeddings-backend') from llm-api.bicep.
  ============================================================================
-->
<policies>
    <inbound>
        <base />

        <!-- Keyless backend auth: attach an AAD bearer token for the Azure OpenAI data
             plane using APIM's managed identity (granted "Cognitive Services OpenAI User"
             in rbac.bicep). No API keys anywhere. Always present (not a flag). -->
        <authentication-managed-identity resource="https://cognitiveservices.azure.com" />

        <!-- modelFailover: route the chat call through the circuit-breaker pool. -->
        <!-- FAILOVER_BACKEND -->

        <!-- tokenRateLimit / tokenQuota / preflightReject: hard spend cap (429 on rate,
             403 on quota). Pre-flight prompt-token estimation rejects over-budget requests
             before they bill the backend. -->
        <!-- TOKEN_LIMIT -->

        <!-- costAttribution: per-team / per-app token metrics into App Insights. -->
        <!-- EMIT_TOKEN_METRIC -->

        <!-- contentSafetyPrompt / contentSafetyResponse: Prompt Shields — jailbreak +
             indirect injection + harm categories, optionally enforced on completions too.
             Blocks (403) before the model. -->
        <!-- CONTENT_SAFETY -->

        <!-- semanticCache (lookup): serve a cached completion for a semantically similar
             prompt. Placed LAST inbound so the cap, attribution, and safety screen always
             evaluate the incoming prompt even on a cache hit. -->
        <!-- SEMANTIC_CACHE_LOOKUP -->
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
        <!-- semanticCache (store): cache the completion for future similar prompts. -->
        <!-- SEMANTIC_CACHE_STORE -->
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
