# Normalize text line endings in the repo, but keep shell scripts LF-only so they
# run on Linux/macOS even when cloned on Windows.
* text=auto eol=lf

*.sh    text eol=lf
*.ps1   text eol=crlf

# Treat these as text with platform-native endings where it doesn't matter.
*.md    text
*.bicep text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.yaml  text eol=lf
